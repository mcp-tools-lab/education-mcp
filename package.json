{
  "name": "education-mcp",
  "version": "1.1.0",
  "description": "AI-powered education tools — quizzes, lesson plans, flashcards, explanations, exercises, rubrics + academic paper search (OpenAlex 250M+ publications) via MCP",
  "author": "SceneView Tools",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "education-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "TERMS.md",
    "PRIVACY.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "keywords": [
    "mcp",
    "education",
    "ai",
    "teaching",
    "quiz",
    "flashcards",
    "lesson-plan",
    "rubric",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tools-lab/education-mcp.git"
  },
  "homepage": "https://github.com/mcp-tools-lab/education-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "funding": [
    {
      "type": "github",
